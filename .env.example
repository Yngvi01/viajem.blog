# Sanity CMS (blog content source)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2025-02-06
# Optional: needed to read drafts in development and CI previews
SANITY_API_TOKEN=

# Optional: Sanity Studio override (if omitted, uses SANITY_* values)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Optional: Webmaster verifications
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
PUBLIC_YANDEX_SITE_VERIFICATION=
