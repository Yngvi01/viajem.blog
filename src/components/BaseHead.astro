---
import YukinaConfig from "../../yukina.config";
import GlobalStyles from "./GlobalStyles.astro";
import ScriptSetup from "./ScriptSetup.astro";
import { getImageSource } from "../utils/imageImports";

const {
  title,
  description,
  keywords,
  attractionImage,
  image,
  published,
  lastModified,
  noindex = false,
} = Astro.props;

const siteURL = new URL(YukinaConfig.site);
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const seoTitle =
  title && title !== YukinaConfig.title
    ? `${title} | ${YukinaConfig.title}`
    : YukinaConfig.title;
const seoDescription = description || YukinaConfig.description;
const seoKeywords = Array.isArray(keywords)
  ? keywords.join(", ")
  : YukinaConfig.keywords;

const toAbsoluteUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) return value;
  return new URL(value.startsWith("/") ? value : `/${value}`, siteURL).href;
};

const rawSocialImage = attractionImage || image;
const resolvedImage = rawSocialImage
  ? getImageSource(rawSocialImage, "images/default-image.jpg")
  : getImageSource(undefined, "images/default-image.jpg");

const socialImagePath =
  typeof resolvedImage === "string"
    ? resolvedImage
    : (resolvedImage?.src ?? "/favicon.png");
const socialImageURL = toAbsoluteUrl(socialImagePath || "/favicon.png");

const isArticle = Boolean(published);
const publishedISO = published ? new Date(published).toISOString() : undefined;
const modifiedISO = lastModified
  ? new Date(lastModified).toISOString()
  : publishedISO;
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const yandexSiteVerification = import.meta.env.PUBLIC_YANDEX_SITE_VERIFICATION;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: YukinaConfig.title,
  url: YukinaConfig.site,
  description: YukinaConfig.description,
  inLanguage: YukinaConfig.locale,
  potentialAction: {
    "@type": "SearchAction",
    target: `${YukinaConfig.site}/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
  sameAs: YukinaConfig.socialLinks
    .filter((link) => link?.link && /^https?:\/\//i.test(link.link))
    .map((link) => link.link),
  publisher: {
    "@type": "Organization",
    name: YukinaConfig.title,
    logo: {
      "@type": "ImageObject",
      url: toAbsoluteUrl("/favicon.png"),
    },
  },
};

const articleSchema =
  isArticle && title
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        image: [socialImageURL],
        author: {
          "@type": "Person",
          name: YukinaConfig.username,
        },
        publisher: {
          "@type": "Organization",
          name: YukinaConfig.title,
          logo: {
            "@type": "ImageObject",
            url: toAbsoluteUrl("/favicon.png"),
          },
        },
        datePublished: publishedISO,
        dateModified: modifiedISO || publishedISO,
        url: canonicalURL,
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalURL,
        },
        description: seoDescription,
        inLanguage: YukinaConfig.locale,
        keywords: seoKeywords,
      }
    : undefined;
---

<script is:inline>
  window.addEventListener(
    "load",
    () => {
      window.setTimeout(() => {
        const i = "GTM-W8FQBNKB";
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" });

        const f = document.getElementsByTagName("script")[0];
        const j = document.createElement("script");
        j.async = true;
        j.src = `https://www.googletagmanager.com/gtm.js?id=${i}`;
        if (f && f.parentNode) f.parentNode.insertBefore(j, f);
      }, 1500);
    },
    { once: true }
  );
</script>

<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
<link rel="preconnect" href="https://cdn.pixabay.com" />

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.png" type="image/png" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={robotsContent} />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)" />
<meta name="author" content={YukinaConfig.username} />
<meta name="format-detection" content="telephone=no" />
{googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
{bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
{yandexSiteVerification && <meta name="yandex-verification" content={yandexSiteVerification} />}

<link rel="canonical" href={canonicalURL} />

<title>{seoTitle}</title>
<meta name="description" content={seoDescription} />
<meta name="keywords" content={seoKeywords} />

<meta property="og:type" content={isArticle ? "article" : "website"} />
<meta property="og:site_name" content={YukinaConfig.title} />
<meta property="og:locale" content={YukinaConfig.locale} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={seoTitle} />
<meta property="og:description" content={seoDescription} />
<meta property="og:image" content={socialImageURL} />
{typeof resolvedImage !== "string" && resolvedImage?.width && (
  <meta property="og:image:width" content={String(resolvedImage.width)} />
)}
{typeof resolvedImage !== "string" && resolvedImage?.height && (
  <meta property="og:image:height" content={String(resolvedImage.height)} />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={seoTitle} />
<meta name="twitter:description" content={seoDescription} />
<meta name="twitter:image" content={socialImageURL} />

{isArticle && publishedISO && <meta property="article:published_time" content={publishedISO} />}
{isArticle && modifiedISO && <meta property="article:modified_time" content={modifiedISO} />}

<link rel="alternate" type="application/rss+xml" title={YukinaConfig.title} href="/rss.xml" />

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
{articleSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
)}

<link
  rel="preload"
  href="/assets/katex/katex.min.css"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript><link rel="stylesheet" href="/assets/katex/katex.min.css" /></noscript>

<GlobalStyles />
<ScriptSetup />
