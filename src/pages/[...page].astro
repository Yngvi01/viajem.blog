---
export const prerender = false;

// Component imports
import Main from "../layouts/MainLayout.astro";
import PostCard from "../components/PostCard.astro";
import Pagination from "../components/controllers/Pagination.astro";
import { GetSortedPosts } from "../utils/content";

const pageSize = 6;
const pageParam = (Astro.params.page ?? "").replace(/^\/+|\/+$/g, "");
const currentPage = pageParam ? Number(pageParam) : 1;

if (
  !Number.isInteger(currentPage) ||
  currentPage < 1 ||
  pageParam.includes("/")
) {
  return new Response("Página não encontrada", { status: 404 });
}

const postCollections = await GetSortedPosts();
const lastPage = Math.max(1, Math.ceil(postCollections.length / pageSize));

if (currentPage > lastPage) {
  return new Response("Página não encontrada", { status: 404 });
}

const start = (currentPage - 1) * pageSize;
const page = {
  currentPage,
  lastPage,
  data: postCollections.slice(start, start + pageSize),
  url: {
    prev:
      currentPage > 1
        ? currentPage === 2
          ? "/"
          : `/${currentPage - 1}`
        : undefined,
    next: currentPage < lastPage ? `/${currentPage + 1}` : undefined,
  },
};

const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage
  ? "Guia de Viagem"
  : `Guia de Viagem - Página ${page.currentPage}`;
const pageDescription = isFirstPage
  ? "Guias de viagem, roteiros completos e dicas práticas para planejar sua próxima aventura no Brasil."
  : `Arquivo de artigos do Guia de Viagem - página ${page.currentPage}.`;

// Configuração do banner para a página principal
const pageBanner = {
  title: pageTitle,
  subTitle: "A direção para sua viagem inesquecivel!",
  bannerImage: "/images/default-banner.jpg",
};
---

<Main
  title={pageBanner.title}
  subTitle={pageBanner.subTitle}
  bannerImage={pageBanner.bannerImage}
  description={pageDescription}
>
  <div class="space-y-8">
    <div class="w-full space-y-4">
      {
        page.data.map((entry, index) => (
          <div
            class="onload-animation"
            style={`animation-delay: calc(var(--onload-animation-delay) + ${index + 1} * var(--onload-animation-interval));`}
          >
            <PostCard
              id={entry.id}
              title={entry.data.title}
              published={entry.data.published}
              category={entry.data.category}
              tags={entry.data.tags}
              description={entry.data.description}
              image={entry.data.cover || entry.data.image}
              attraction_image={entry.data.attraction_image}
            />
          </div>
        ))
      }
    </div>
    <Pagination
      class="onload-animation"
      lastPage={page.lastPage}
      current={page.currentPage}
      prevURL={page.url.prev}
      nextURL={page.url.next}
      style={`animation-delay: calc(var(--onload-animation-delay) + ${page.data.length + 1} * var(--onload-animation-interval));`}
    />
  </div>
</Main>
