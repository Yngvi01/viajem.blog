---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { sanityWriteClient, isSanityWriteEnabled } from "../../utils/sanityAdminClient";

let error = "";
let success = "";
const sanityOk = isSanityWriteEnabled();

const toSlug = (text: string): string => {
  return text
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .slice(0, 96);
};

if (Astro.request.method === "POST" && sanityOk) {
  try {
    const form = await Astro.request.formData();
    const action = String(form.get("action") ?? "");

    if (action === "create-category") {
      const title = String(form.get("title") ?? "").trim();
      if (!title) throw new Error("O nome da categoria é obrigatório.");
      const slug = toSlug(title);

      // Verificar duplicidade
      const existing = await sanityWriteClient.fetch<number>(
        `count(*[_type == "category" && (title == $title || slug.current == $slug)])`,
        { title, slug }
      );
      if (existing > 0) throw new Error("Uma categoria com este nome ou slug já existe.");

      await sanityWriteClient.create({
        _type: "category",
        title,
        slug: { _type: "slug", current: slug },
      });
      success = `Categoria "${title}" criada com sucesso.`;
    } else if (action === "create-tag") {
      const title = String(form.get("title") ?? "").trim();
      if (!title) throw new Error("O nome da tag é obrigatório.");
      const slug = toSlug(title);

      // Verificar duplicidade
      const existing = await sanityWriteClient.fetch<number>(
        `count(*[_type == "tag" && (title == $title || slug.current == $slug)])`,
        { title, slug }
      );
      if (existing > 0) throw new Error("Uma tag com este nome ou slug já existe.");

      await sanityWriteClient.create({
        _type: "tag",
        title,
        slug: { _type: "slug", current: slug },
      });
      success = `Tag "${title}" criada com sucesso.`;
    } else if (action === "delete") {
      const id = String(form.get("id") ?? "");
      const type = String(form.get("type") ?? "");
      if (!id) throw new Error("ID inválido para exclusão.");

      await sanityWriteClient.delete(id);
      success = `${type === "category" ? "Categoria" : "Tag"} excluída com sucesso.`;
    }
  } catch (e: any) {
    error = e?.message ?? "Erro ao processar a requisição.";
  }
}

// Buscar categorias e tags atualizadas
const categories = sanityOk
  ? await sanityWriteClient.fetch<{ _id: string; title: string; slug: { current: string } }[]>(
      `*[_type == "category"] | order(title asc) { _id, title, slug }`
    )
  : [];

const tags = sanityOk
  ? await sanityWriteClient.fetch<{ _id: string; title: string; slug: { current: string } }[]>(
      `*[_type == "tag"] | order(title asc) { _id, title, slug }`
    )
  : [];
---

<AdminLayout title="Categorias & Tags" activeNav="categorias-tags">
  <style>
    .tax-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    @media (max-width: 1024px) {
      .tax-grid {
        grid-template-columns: 1fr;
        gap: 24px;
      }
    }

    .tax-card {
      background: #161922;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .tax-title {
      font-size: 16px;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 12px;
    }

    .tax-form {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }

    .tax-form input {
      flex: 1;
      padding: 9px 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      color: #e2e8f0;
      font-size: 13px;
      outline: none;
      transition: border-color 0.15s;
    }

    .tax-form input:focus {
      border-color: rgba(99,102,241,0.5);
    }

    .btn-add {
      padding: 9px 16px;
      background: linear-gradient(135deg, #6366f1, #818cf8);
      border: none;
      border-radius: 8px;
      color: white;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s;
      white-space: nowrap;
    }

    .btn-add:hover {
      opacity: 0.9;
    }

    .tax-list {
      flex: 1;
      max-height: 480px;
      overflow-y: auto;
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 8px;
      background: rgba(0,0,0,0.1);
    }

    .tax-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 13px;
      transition: background 0.1s;
    }

    .tax-item:last-child {
      border-bottom: none;
    }

    .tax-item:hover {
      background: rgba(255,255,255,0.02);
    }

    .tax-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .tax-name {
      font-weight: 500;
      color: #e2e8f0;
    }

    .tax-slug {
      font-size: 11px;
      color: #64748b;
      font-family: monospace;
    }

    .btn-delete-tax {
      background: none;
      border: none;
      color: #f87171;
      padding: 4px;
      cursor: pointer;
      border-radius: 4px;
      transition: background 0.15s, color 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-delete-tax:hover {
      background: rgba(239,68,68,0.15);
      color: #ef4444;
    }

    .empty-tax {
      padding: 32px 16px;
      text-align: center;
      color: #64748b;
      font-style: italic;
      font-size: 13px;
    }

    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .alert-error {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.25);
      color: #f87171;
    }

    .alert-success {
      background: rgba(34,197,94,0.1);
      border: 1px solid rgba(34,197,94,0.25);
      color: #4ade80;
    }
  </style>

  {error && (
    <div class="alert alert-error">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>{error}</span>
    </div>
  )}

  {success && (
    <div class="alert alert-success">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>{success}</span>
    </div>
  )}

  <div class="tax-grid">
    <!-- Bloco de Categorias -->
    <div class="tax-card">
      <h2 class="tax-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        Categorias
      </h2>

      <form method="POST" class="tax-form">
        <input type="hidden" name="action" value="create-category" />
        <input type="text" name="title" placeholder="Nova categoria..." required disabled={!sanityOk} />
        <button type="submit" class="btn-add" disabled={!sanityOk}>Adicionar</button>
      </form>

      <div class="tax-list">
        {categories.length === 0 ? (
          <div class="empty-tax">Nenhuma categoria cadastrada.</div>
        ) : (
          categories.map((cat) => (
            <div class="tax-item">
              <div class="tax-info">
                <span class="tax-name">{cat.title}</span>
                <span class="tax-slug">/categorias/{cat.slug?.current}</span>
              </div>
              <form method="POST" style="margin: 0;" onsubmit="return confirm('Tem certeza que deseja excluir esta categoria? Os posts associados perderão o vínculo.');">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="type" value="category" />
                <input type="hidden" name="id" value={cat._id} />
                <button type="submit" class="btn-delete-tax" title="Excluir Categoria" disabled={!sanityOk}>
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </form>
            </div>
          ))
        )}
      </div>
    </div>

    <!-- Bloco de Tags -->
    <div class="tax-card">
      <h2 class="tax-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7c.78.78.78 2.047 0 2.828l-5 5c-.78.78-2.047.78-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        Tags
      </h2>

      <form method="POST" class="tax-form">
        <input type="hidden" name="action" value="create-tag" />
        <input type="text" name="title" placeholder="Nova tag..." required disabled={!sanityOk} />
        <button type="submit" class="btn-add" disabled={!sanityOk}>Adicionar</button>
      </form>

      <div class="tax-list">
        {tags.length === 0 ? (
          <div class="empty-tax">Nenhuma tag cadastrada.</div>
        ) : (
          tags.map((tag) => (
            <div class="tax-item">
              <div class="tax-info">
                <span class="tax-name">{tag.title}</span>
                <span class="tax-slug">/tags/{tag.slug?.current}</span>
              </div>
              <form method="POST" style="margin: 0;" onsubmit="return confirm('Tem certeza que deseja excluir esta tag?');">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="type" value="tag" />
                <input type="hidden" name="id" value={tag._id} />
                <button type="submit" class="btn-delete-tax" title="Excluir Tag" disabled={!sanityOk}>
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </form>
            </div>
          ))
        )}
      </div>
    </div>
  </div>
</AdminLayout>
