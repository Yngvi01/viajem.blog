---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { IsSanityEnabled, GetSanityPosts } from "../../utils/sanity";

let posts: Awaited<ReturnType<typeof GetSanityPosts>> = [];
let sanityEnabled = IsSanityEnabled();
let fetchError = "";

if (sanityEnabled) {
  try {
    posts = await GetSanityPosts({ includeDrafts: true });
  } catch (e) {
    fetchError = "Não foi possível conectar ao Sanity. Verifique as variáveis de ambiente.";
  }
}

// 1. Métricas Gerais
const totalPosts = posts.length;
const publishedPosts = posts.filter((p) => !p.draft).length;
const draftPosts = posts.filter((p) => p.draft).length;

// Calcular Tempo de Leitura Médio
let totalWords = 0;
posts.forEach((p) => {
  const text = (p.contentHtml || "").replace(/<[^>]*>/g, " ");
  const words = text.split(/\s+/).filter(Boolean).length;
  totalWords += words;
});
const avgWords = totalPosts > 0 ? Math.round(totalWords / totalPosts) : 0;
const avgReadTime = Math.round(avgWords / 200); // 200 PPM

// 2. Gráfico de Histórico de Publicações (Últimos 6 Meses)
const monthNames = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"];
const last6Months: { name: string; monthIndex: number; year: number; count: number }[] = [];

for (let i = 5; i >= 0; i--) {
  const d = new Date();
  d.setMonth(d.getMonth() - i);
  last6Months.push({
    name: monthNames[d.getMonth()],
    monthIndex: d.getMonth(),
    year: d.getFullYear(),
    count: 0
  });
}

posts.forEach((post) => {
  const postDate = new Date(post.published);
  const postMonth = postDate.getMonth();
  const postYear = postDate.getFullYear();
  
  const match = last6Months.find((m) => m.monthIndex === postMonth && m.year === postYear);
  if (match) {
    match.count++;
  }
});

// Coordenadas SVG para o Gráfico de Histórico
const svgWidth = 500;
const svgHeight = 200;
const chartMaxCount = Math.max(...last6Months.map((m) => m.count), 0);
const maxYVal = chartMaxCount > 0 ? chartMaxCount : 1;

// Gerar pontos (X: 40 a 460, Y: 30 a 170)
const points = last6Months.map((m, i) => {
  const x = 40 + i * 84;
  const y = 170 - (m.count / maxYVal) * 130;
  return { x, y, count: m.count, name: m.name };
});

const linePath = points.map((p, i) => (i === 0 ? `M ${p.x} ${p.y}` : `L ${p.x} ${p.y}`)).join(" ");
const areaPath = points.length > 0 ? `${linePath} L ${points[points.length - 1].x} 170 L ${points[0].x} 170 Z` : "";

// 3. Gráfico de Categorias
const categoryCounts: Record<string, number> = {};
posts.forEach((p) => {
  const cat = p.category || "Sem Categoria";
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
});
const categoriesData = Object.entries(categoryCounts)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const maxCatCount = categoriesData.length > 0 ? categoriesData[0].count : 1;

// 4. Tags mais populares
const tagCounts: Record<string, number> = {};
posts.forEach((p) => {
  if (p.tags && Array.isArray(p.tags)) {
    p.tags.forEach((t) => {
      tagCounts[t] = (tagCounts[t] || 0) + 1;
    });
  }
});
const tagsData = Object.entries(tagCounts)
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 8); // Top 8 tags

// 5. Atividades Recentes (Últimos 3 posts criados/modificados)
const recentPosts = [...posts]
  .sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime())
  .slice(0, 3);
---

<AdminLayout title="Dashboard de Dados" activeNav="dashboard">
  <style>
    /* ── Grid de Métricas Principais ──────────────────────────────── */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .metric-card {
      background: #161922;
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 12px;
      padding: 24px;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .metric-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }

    .metric-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    
    .metric-card.total::before { background: linear-gradient(90deg, #6366f1, #818cf8); }
    .metric-card.published::before { background: linear-gradient(90deg, #22c55e, #4ade80); }
    .metric-card.drafts::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .metric-card.readtime::before { background: linear-gradient(90deg, #0ea5e9, #38bdf8); }

    .metric-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .metric-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
    }

    .metric-icon {
      color: #64748b;
      opacity: 0.8;
    }

    .metric-value {
      font-size: 38px;
      font-weight: 700;
      color: #f1f5f9;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .metric-footer {
      font-size: 12px;
      color: #64748b;
      margin-top: 4px;
    }

    /* ── Layout dos Gráficos e Tabelas ──────────────────────────────── */
    .dashboard-row {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 24px;
      margin-bottom: 24px;
    }

    @media (max-width: 1024px) {
      .dashboard-row {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: #161922;
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      flex-direction: column;
    }

    .card-title {
      font-size: 15px;
      font-weight: 600;
      color: #f1f5f9;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .card-title svg {
      color: #818cf8;
    }

    /* ── Gráfico de Histórico SVG ────────────────────────────────── */
    .chart-container {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 200px;
    }

    .chart-svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .grid-line {
      stroke: rgba(255, 255, 255, 0.05);
      stroke-width: 1;
      stroke-dasharray: 4;
    }

    .axis-line {
      stroke: rgba(255, 255, 255, 0.1);
      stroke-width: 1;
    }

    .chart-line {
      stroke: #6366f1;
      stroke-width: 3;
      fill: none;
      stroke-linecap: round;
    }

    .chart-area {
      fill: url(#chart-gradient);
      opacity: 0.15;
    }

    .chart-point {
      fill: #161922;
      stroke: #818cf8;
      stroke-width: 2.5;
      cursor: pointer;
      transition: r 0.15s, fill 0.15s;
    }

    .chart-point:hover {
      r: 7;
      fill: #818cf8;
    }

    .chart-text {
      fill: #64748b;
      font-size: 10px;
      font-family: inherit;
      text-anchor: middle;
    }

    .chart-value-label {
      fill: #e2e8f0;
      font-size: 10px;
      font-weight: 600;
      text-anchor: middle;
    }

    /* ── Gráfico de Categorias ──────────────────────────────────── */
    .categories-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .category-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .category-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12.5px;
    }

    .category-name {
      font-weight: 500;
      color: #cbd5e1;
    }

    .category-count {
      font-weight: 600;
      color: #94a3b8;
    }

    .progress-bar-bg {
      height: 8px;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 4px;
      overflow: hidden;
      width: 100%;
    }

    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #6366f1, #c084fc);
      border-radius: 4px;
      transition: width 0.5s ease-out;
    }

    /* ── Nuvem de Tags e Atividade Recente ────────────────────────── */
    .tags-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .tag-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 500;
      transition: background 0.15s, border-color 0.15s;
    }

    .tag-pill.tier-1 {
      background: rgba(99, 102, 241, 0.15);
      color: #c7d2fe;
      border: 1px solid rgba(99, 102, 241, 0.3);
      font-size: 13.5px;
      font-weight: 600;
    }

    .tag-pill.tier-2 {
      background: rgba(192, 132, 252, 0.1);
      color: #e9d5ff;
      border: 1px solid rgba(192, 132, 252, 0.2);
      font-size: 12.5px;
    }

    .tag-pill.tier-3 {
      background: rgba(255, 255, 255, 0.04);
      color: #94a3b8;
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-size: 11.5px;
    }

    .tag-pill:hover {
      background: rgba(99, 102, 241, 0.25);
      border-color: rgba(99, 102, 241, 0.5);
    }

    .tag-pill-count {
      font-size: 10px;
      opacity: 0.7;
      background: rgba(0, 0, 0, 0.2);
      padding: 1px 5px;
      border-radius: 10px;
    }

    .recent-activity-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .activity-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .activity-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .activity-details {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .activity-title {
      font-size: 13px;
      font-weight: 500;
      color: #e2e8f0;
      text-decoration: none;
      transition: color 0.15s;
    }

    .activity-title:hover {
      color: #818cf8;
    }

    .activity-meta {
      font-size: 11px;
      color: #64748b;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .activity-action {
      font-size: 11.5px;
      color: #818cf8;
      font-weight: 600;
      text-decoration: none;
      padding: 4px 8px;
      border-radius: 6px;
      background: rgba(99, 102, 241, 0.08);
      border: 1px solid rgba(99, 102, 241, 0.15);
      transition: background 0.15s, color 0.15s;
    }

    .activity-action:hover {
      background: rgba(99, 102, 241, 0.15);
      color: #c7d2fe;
    }

    .badge {
      display: inline-block;
      padding: 1px 5px;
      border-radius: 4px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
    }

    .badge-published {
      background: rgba(34, 197, 94, 0.1);
      color: #4ade80;
    }

    .badge-draft {
      background: rgba(245, 158, 11, 0.1);
      color: #fbbf24;
    }

    .alert {
      padding: 14px 18px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 24px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .alert-warning {
      background: rgba(245, 158, 11, 0.1);
      border: 1px solid rgba(245, 158, 11, 0.25);
      color: #fbbf24;
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #f87171;
    }
  </style>

  <!-- Avisos de configuração -->
  {!sanityEnabled && (
    <div class="alert alert-warning">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>
        <strong>Sanity não configurado.</strong> Preencha as variáveis de ambiente no arquivo <code>.env</code> para gerenciar posts.
      </span>
    </div>
  )}

  {fetchError && (
    <div class="alert alert-error">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      {fetchError}
    </div>
  )}

  <!-- Grid de Métricas Gerais -->
  <div class="metrics-grid">
    <div class="metric-card total">
      <div class="metric-header">
        <span class="metric-label">Total de Posts</span>
        <svg class="metric-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
      </div>
      <div class="metric-value">{totalPosts}</div>
      <div class="metric-footer">Artigos no banco de dados</div>
    </div>

    <div class="metric-card published">
      <div class="metric-header">
        <span class="metric-label">Publicados</span>
        <svg class="metric-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="metric-value">{publishedPosts}</div>
      <div class="metric-footer">Visíveis para os leitores</div>
    </div>

    <div class="metric-card drafts">
      <div class="metric-header">
        <span class="metric-label">Rascunhos</span>
        <svg class="metric-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
      </div>
      <div class="metric-value">{draftPosts}</div>
      <div class="metric-footer">Aguardando publicação</div>
    </div>

    <div class="metric-card readtime">
      <div class="metric-header">
        <span class="metric-label">Leitura Média</span>
        <svg class="metric-icon" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="metric-value">{avgReadTime} min</div>
      <div class="metric-footer">Média de {avgWords} palavras por post</div>
    </div>
  </div>

  <!-- Primeira Linha de Gráficos -->
  <div class="dashboard-row">
    <!-- Gráfico Histórico SVG -->
    <div class="card">
      <div class="card-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        Frequência de Publicações (Últimos 6 Meses)
      </div>
      
      <div class="chart-container">
        {totalPosts === 0 ? (
          <div style="height: 100%; display: flex; align-items: center; justify-content: center; color: #64748b; font-size: 13px;">
            Nenhum dado disponível para exibir no gráfico.
          </div>
        ) : (
          <svg viewBox={`0 0 ${svgWidth} ${svgHeight}`} class="chart-svg">
            <defs>
              <linearGradient id="chart-gradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#6366f1" />
                <stop offset="100%" stop-color="#6366f1" stop-opacity="0" />
              </linearGradient>
            </defs>

            <!-- Grid Lines -->
            <line x1="40" y1="30" x2="460" y2="30" class="grid-line" />
            <line x1="40" y1="100" x2="460" y2="100" class="grid-line" />
            <line x1="40" y1="170" x2="460" y2="170" class="axis-line" />

            <!-- Labels Y -->
            <text x="30" y="34" class="chart-text" style="text-anchor: end;">{chartMaxCount}</text>
            <text x="30" y="104" class="chart-text" style="text-anchor: end;">{Math.round(chartMaxCount / 2)}</text>
            <text x="30" y="174" class="chart-text" style="text-anchor: end;">0</text>

            <!-- Filled Area -->
            {areaPath && <path d={areaPath} class="chart-area" />}

            <!-- Line -->
            {linePath && <path d={linePath} class="chart-line" />}

            <!-- Grid X & labels & circles -->
            {points.map((p) => (
              <g>
                <line x1={p.x} y1="170" x2={p.x} y2="175" class="axis-line" />
                <text x={p.x} y="192" class="chart-text">{p.name}</text>
                
                {/* Exibir número de posts acima da bola */}
                <text x={p.x} y={p.y - 10} class="chart-value-label">{p.count}</text>
                
                <circle cx={p.x} cy={p.y} r="4.5" class="chart-point" title={`${p.count} posts em ${p.name}`} />
              </g>
            ))}
          </svg>
        )}
      </div>
    </div>

    <!-- Gráfico de Categorias -->
    <div class="card">
      <div class="card-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        Posts por Categoria
      </div>

      <div class="categories-list">
        {categoriesData.length === 0 ? (
          <div style="color: #64748b; font-size: 13px; text-align: center; padding: 20px;">
            Nenhuma categoria encontrada.
          </div>
        ) : (
          categoriesData.map((cat) => {
            const percentage = (cat.count / maxCatCount) * 100;
            return (
              <div class="category-item">
                <div class="category-info">
                  <span class="category-name">{cat.name}</span>
                  <span class="category-count">{cat.count} {cat.count === 1 ? 'post' : 'posts'}</span>
                </div>
                <div class="progress-bar-bg">
                  <div class="progress-bar-fill" style={{ width: `${percentage}%` }}></div>
                </div>
              </div>
            );
          })
        )}
      </div>
    </div>
  </div>

  <!-- Segunda Linha de Gráficos -->
  <div class="dashboard-row">
    <!-- Tags mais populares -->
    <div class="card">
      <div class="card-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7c.78.78.78 2.047 0 2.828l-5 5c-.78.78-2.047.78-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
        </svg>
        Tags Mais Populares
      </div>

      <div class="tags-cloud">
        {tagsData.length === 0 ? (
          <div style="color: #64748b; font-size: 13px; text-align: center; width: 100%; padding: 20px;">
            Nenhuma tag encontrada nos posts.
          </div>
        ) : (
          tagsData.map((tag, index) => {
            // Dividir as tags em 3 níveis de peso/tamanho baseado no índice
            let tierClass = "tier-3";
            if (index < 2) tierClass = "tier-1";
            else if (index < 5) tierClass = "tier-2";

            return (
              <span class={`tag-pill ${tierClass}`} title={`${tag.count} posts utilizam esta tag`}>
                #{tag.name}
                <span class="tag-pill-count">{tag.count}</span>
              </span>
            );
          })
        )}
      </div>
    </div>

    <!-- Atividades Recentes -->
    <div class="card">
      <div class="card-title">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Artigos Adicionados Recentemente
      </div>

      <div class="recent-activity-list">
        {recentPosts.length === 0 ? (
          <div style="color: #64748b; font-size: 13px; text-align: center; padding: 20px;">
            Nenhum post publicado recentemente.
          </div>
        ) : (
          recentPosts.map((post) => (
            <div class="activity-item">
              <div class="activity-details">
                <a
                  href={post.draft ? `/admin/posts/${post.slug}/preview` : `/posts/${post.slug}`}
                  target="_blank"
                  class="activity-title"
                >
                  {post.title}
                </a>
                <div class="activity-meta">
                  <span class={`badge ${post.draft ? 'badge-draft' : 'badge-published'}`}>
                    {post.draft ? 'Rascunho' : 'Publicado'}
                  </span>
                  <span>•</span>
                  <span>{new Date(post.published).toLocaleDateString('pt-BR')}</span>
                </div>
              </div>
              <a href={`/admin/posts/${post.slug}/editar`} class="activity-action">
                Editar
              </a>
            </div>
          ))
        )}
      </div>
    </div>
  </div>
</AdminLayout>
