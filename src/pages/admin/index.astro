---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { IsSanityEnabled, GetSanityPosts } from "../../utils/sanity";

let posts: Awaited<ReturnType<typeof GetSanityPosts>> = [];
let sanityEnabled = IsSanityEnabled();
let fetchError = "";

if (sanityEnabled) {
  try {
    posts = await GetSanityPosts({ includeDrafts: true });
  } catch (e) {
    fetchError = "Não foi possível conectar ao Sanity. Verifique as variáveis de ambiente.";
  }
}

const published = posts.filter((p) => !p.draft);
const drafts = posts.filter((p) => p.draft);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}
---

<AdminLayout title="Dashboard" activeNav="dashboard">
  <style>
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: #161922;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
    }
    .stat-card.total::before { background: linear-gradient(90deg, #6366f1, #818cf8); }
    .stat-card.published::before { background: linear-gradient(90deg, #22c55e, #4ade80); }
    .stat-card.drafts::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }

    .stat-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 36px;
      font-weight: 700;
      color: #e2e8f0;
      line-height: 1;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .section-title {
      font-size: 15px;
      font-weight: 600;
      color: #e2e8f0;
    }

    .btn-new {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: linear-gradient(135deg, #6366f1, #818cf8);
      border-radius: 8px;
      color: white;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.15s, transform 0.1s;
      box-shadow: 0 4px 12px rgba(99,102,241,0.35);
    }

    .btn-new:hover { opacity: 0.9; transform: translateY(-1px); }

    .posts-table {
      background: #161922;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      overflow: hidden;
    }

    .posts-table table {
      width: 100%;
      border-collapse: collapse;
    }

    .posts-table th {
      padding: 12px 16px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .posts-table td {
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: middle;
    }

    .posts-table tr:last-child td { border-bottom: none; }

    .posts-table tr:hover td {
      background: rgba(255,255,255,0.02);
    }

    .post-title-cell {
      font-weight: 500;
      color: #e2e8f0;
      font-size: 13px;
      max-width: 340px;
    }

    .post-title-link {
      color: inherit;
      text-decoration: none;
      transition: color 0.15s;
    }

    .post-title-link:hover { color: #818cf8; }

    .badge {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }

    .badge-published {
      background: rgba(34,197,94,0.12);
      color: #4ade80;
      border: 1px solid rgba(34,197,94,0.2);
    }

    .badge-draft {
      background: rgba(245,158,11,0.12);
      color: #fbbf24;
      border: 1px solid rgba(245,158,11,0.2);
    }

    .actions {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .btn-edit, .btn-delete {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 500;
      transition: background 0.15s;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }

    .btn-edit {
      background: rgba(99,102,241,0.12);
      color: #818cf8;
      border: 1px solid rgba(99,102,241,0.2);
    }

    .btn-edit:hover { background: rgba(99,102,241,0.22); }

    .btn-delete {
      background: rgba(239,68,68,0.08);
      color: #f87171;
      border: 1px solid rgba(239,68,68,0.2);
    }

    .btn-delete:hover { background: rgba(239,68,68,0.16); }

    .date-cell {
      color: #64748b;
      font-size: 12px;
      white-space: nowrap;
    }

    .empty-state {
      padding: 48px 24px;
      text-align: center;
      color: #64748b;
    }

    .empty-state svg {
      width: 40px;
      height: 40px;
      margin: 0 auto 12px;
      opacity: 0.4;
    }

    .empty-state p { font-size: 14px; }

    .alert {
      padding: 14px 18px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 24px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .alert-warning {
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.25);
      color: #fbbf24;
    }

    .alert-error {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.25);
      color: #f87171;
    }
  </style>

  <!-- Avisos de configuração -->
  {!sanityEnabled && (
    <div class="alert alert-warning">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>
        <strong>Sanity não configurado.</strong> Preencha as variáveis <code>SANITY_PROJECT_ID</code>, <code>SANITY_DATASET</code> e <code>SANITY_API_TOKEN</code> no arquivo <code>.env</code> para gerenciar posts.
      </span>
    </div>
  )}

  {fetchError && (
    <div class="alert alert-error">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      {fetchError}
    </div>
  )}

  <!-- Cards de estatísticas -->
  <div class="stats-grid">
    <div class="stat-card total">
      <div class="stat-label">Total de Posts</div>
      <div class="stat-value">{posts.length}</div>
    </div>
    <div class="stat-card published">
      <div class="stat-label">Publicados</div>
      <div class="stat-value">{published.length}</div>
    </div>
    <div class="stat-card drafts">
      <div class="stat-label">Rascunhos</div>
      <div class="stat-value">{drafts.length}</div>
    </div>
  </div>

  <!-- Tabela de posts -->
  <div class="section-header">
    <span class="section-title">Posts</span>
    <a href="/admin/posts/novo" class="btn-new">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Novo Post
    </a>
  </div>

  <div class="posts-table">
    {posts.length === 0 ? (
      <div class="empty-state">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" display="block">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p>Nenhum post encontrado. <a href="/admin/posts/novo" style="color:#818cf8">Criar o primeiro post →</a></p>
      </div>
    ) : (
      <table>
        <thead>
          <tr>
            <th>Título</th>
            <th>Status</th>
            <th>Data</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          {posts.map((post) => (
            <tr>
              <td class="post-title-cell">
                <a
                  href={`/posts/${post.slug}`}
                  target="_blank"
                  class="post-title-link"
                  title="Ver no blog"
                >
                  {post.title}
                </a>
              </td>
              <td>
                <span class={`badge ${post.draft ? "badge-draft" : "badge-published"}`}>
                  {post.draft ? "Rascunho" : "Publicado"}
                </span>
              </td>
              <td class="date-cell">{formatDate(post.published)}</td>
              <td>
                <div class="actions">
                  <a href={`/admin/posts/${post.slug}/editar`} class="btn-edit">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Editar
                  </a>
                  <a href={`/admin/posts/${post.slug}/excluir`} class="btn-delete">
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Excluir
                  </a>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
