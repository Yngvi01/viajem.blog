---
export const prerender = false;

import PostLayout from "../../../../layouts/PostLayout.astro";
import { GetSanityPosts } from "../../../../utils/sanity";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/admin", 302);

const posts = await GetSanityPosts({ includeDrafts: true });
const post = posts.find((item) => item.slug === slug);

if (!post) {
  return new Response("Post não encontrado", { status: 404 });
}

const DEFAULT_BANNER = "/images/default-banner.jpg";
const postBanner = {
  title: post.title,
  subTitle: post.description || "Sua próxima aventura começa aqui!",
  bannerImage: post.licenseName
    ? post.cover || DEFAULT_BANNER
    : post.attraction_image || post.cover || DEFAULT_BANNER,
};

const licenseData = post.licenseName && {
  license: {
    name: post.licenseName,
    url: post.licenseUrl,
  },
  author: post.author,
  sourceLink: post.sourceLink,
};
---

<PostLayout
  title={`Prévia: ${post.title}`}
  subTitle={postBanner.subTitle}
  bannerImage={postBanner.bannerImage}
  description={post.description}
  image={post.meta_image || post.attraction_image || post.cover || post.image}
  attractionImage={post.attraction_image}
  keywords={post.keywords}
  published={new Date(post.published)}
  lastModified={post.lastModified ? new Date(post.lastModified) : new Date(post.published)}
  slug={post.slug}
  {...licenseData}
>
  <aside class="admin-preview-notice">
    <strong>{post.draft ? "Rascunho" : "Publicado"}</strong>
    <span>Prévia administrativa do conteúdo que será exibido no blog.</span>
    <a href={`/admin/posts/${post.slug}/editar`}>Editar</a>
  </aside>

  {post.contentHtml ? <div set:html={post.contentHtml} /> : <p>Conteúdo em atualização.</p>}
</PostLayout>

<style>
  .admin-preview-notice {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(99, 102, 241, 0.28);
    border-radius: 0.5rem;
    background: rgba(99, 102, 241, 0.1);
    color: var(--text-color);
  }

  .admin-preview-notice strong {
    color: var(--primary-color);
  }

  .admin-preview-notice a {
    margin-left: auto;
    color: var(--primary-color);
    font-weight: 700;
  }
</style>
