---
export const prerender = true;

import { render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { IdToSlug } from "../../utils/hash";
import { GetSortedPosts, type BlogPostEntry } from "../../utils/content";

export async function getStaticPaths() {
  const postEntries = await GetSortedPosts();
  const paths: Array<{
    params: { slug: string };
    props: {
      entry: BlogPostEntry;
      canonicalSlug: string;
      isLegacySlug: boolean;
    };
  }> = [];
  const seen = new Set<string>();

  for (const entry of postEntries) {
    const canonicalSlug = IdToSlug(entry.id);
    if (!seen.has(canonicalSlug)) {
      paths.push({
        params: { slug: canonicalSlug },
        props: { entry, canonicalSlug, isLegacySlug: false },
      });
      seen.add(canonicalSlug);
    }

    const legacySlugs = entry.data.legacySlugs || [];
    for (const rawSlug of legacySlugs) {
      const legacySlug = rawSlug.trim().replace(/^\/+|\/+$/g, "");
      if (!legacySlug || legacySlug === canonicalSlug || seen.has(legacySlug)) continue;

      paths.push({
        params: { slug: legacySlug },
        props: { entry, canonicalSlug, isLegacySlug: true },
      });
      seen.add(legacySlug);
    }
  }

  return paths;
}

interface Props {
  entry: BlogPostEntry;
  canonicalSlug: string;
  isLegacySlug: boolean;
}

const { entry, canonicalSlug, isLegacySlug } = Astro.props as Props;

let LocalContent: any = null;
if (!isLegacySlug && entry.source === "local" && entry.rawEntry) {
  const { Content } = await render(entry.rawEntry);
  LocalContent = Content;
}

const DEFAULT_BANNER = "/images/default-banner.jpg";
const postSlug = canonicalSlug;
const redirectDestination = `/posts/${canonicalSlug}`;

const licenseData = entry.data.licenseName && {
  license: {
    name: entry.data.licenseName,
    url: entry.data.licenseUrl,
  },
  author: entry.data.author,
  sourceLink: entry.data.sourceLink,
};

const postBanner = {
  title: entry.data.title,
  subTitle: entry.data.description || "Sua próxima aventura começa aqui!",
  bannerImage: entry.data.licenseName
    ? entry.data.cover || DEFAULT_BANNER
    : entry.data.attraction_image || DEFAULT_BANNER,
};

const hasSanityContent = entry.source === "sanity" && Boolean(entry.contentHtml);
---

{
  isLegacySlug ? (
    <html lang="pt-BR">
      <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex, follow" />
        <meta http-equiv="refresh" content={`0;url=${redirectDestination}`} />
        <link rel="canonical" href={redirectDestination} />
        <title>Redirecionando...</title>
        <script is:inline>{`window.location.replace(${JSON.stringify(redirectDestination)});`}</script>
      </head>
      <body>
        <p>
          Redirecionando para{" "}
          <a href={redirectDestination}>{redirectDestination}</a>.
        </p>
      </body>
    </html>
  ) : (
    <PostLayout
      title={entry.data.title}
      subTitle={postBanner.subTitle}
      bannerImage={postBanner.bannerImage}
      description={entry.data.description}
      image={entry.data.meta_image || entry.data.attraction_image || entry.data.cover || entry.data.image}
      attractionImage={entry.data.attraction_image}
      keywords={entry.data.keywords}
      published={entry.data.published}
      lastModified={entry.data.lastModified || entry.data.published}
      slug={postSlug}
      {...licenseData}
    >
      <div
        class="hidden"
        data-pagefind-body
        data-pagefind-weight="10"
        data-pagefind-meta="title"
      >
        {entry.data.title}
      </div>

      <div data-pagefind-body>
        {
          hasSanityContent ? (
            <div set:html={entry.contentHtml} />
          ) : entry.source === "sanity" ? (
            <p>Conteúdo em atualização.</p>
          ) : (
            LocalContent && <LocalContent />
          )
        }
      </div>
    </PostLayout>
  )
}

<style>
  .attraction-image {
    @apply mt-8 w-full rounded-lg shadow-xl;
    max-height: 60vh;
    object-fit: cover;
  }
</style>
